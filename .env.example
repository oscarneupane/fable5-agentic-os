# --- Fable5 model configuration ---
# The system runs fully offline with none of these set. Add a provider + API key
# to enable live LLM calls.
#
# DEFAULT: GLM / Zhipu AI (free tier, works out of the box).
# Get a free key at https://z.ai or https://open.bigmodel.cn and paste it below.
FABLE5_PROVIDER=glm
FABLE5_MODEL=glm-4.5-flash
#
# --- Optional: mix providers per agent (cheap for light work, strong for hard) ---
# Any unset agent uses FABLE5_PROVIDER / FABLE5_MODEL above.
#   FABLE5_PROVIDER_CODER=openrouter
#   FABLE5_MODEL_CODER=anthropic/claude-opus-4.8
#   FABLE5_PROVIDER_VALIDATOR=openrouter
#   FABLE5_MODEL_VALIDATOR=openai/gpt-4o-mini
#
# --- Other providers ---
#   FABLE5_PROVIDER=openrouter  FABLE5_MODEL=openai/gpt-4o-mini   (needs ~$10 credit)
#   FABLE5_PROVIDER=openai      FABLE5_MODEL=gpt-4o-mini
#   FABLE5_PROVIDER=anthropic, groq, ollama, ...
# base_url is auto-resolved for glm/openrouter; override with FABLE5_BASE_URL if needed.
FABLE5_TEMPERATURE=0.1
FABLE5_MAX_REVISIONS=1
# Set to true to force deterministic offline mode even if a key is present.
FABLE5_OFFLINE=false

# Validator strictness: lenient | balanced | strict (default: balanced)
FABLE5_STRICTNESS=balanced
# Agent behavior layer: ponytail (lazy-senior-dev, minimal code) | none
# Adapted from https://github.com/DietrichGebert/ponytail (MIT).
FABLE5_BEHAVIOR=ponytail
# Run researcher + designer concurrently. true = parallel subagents (default),
# false = classic linear pipeline.
FABLE5_PARALLEL=true
# Whether the coder writes generated files to disk, and where.
FABLE5_WRITE_CODE=true
FABLE5_OUTPUT_DIR=generated

# --- Provider API key (set the one matching FABLE5_PROVIDER) ---
GLM_API_KEY=your_glm_api_key
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key   (needs ~$10 credit to run)
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key

# --- LangSmith tracing (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=fable5-agentic-os
